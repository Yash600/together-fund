# Required: get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Required: get a free key at https://tavily.com (~1000 searches/month free)
TAVILY_API_KEY=your_tavily_api_key_here

# Optional: model override (defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: port for the FastAPI server (defaults to 8002)
PORT=8002
